# ========================================================
# WhatsApp Agent Template Platform Config Template
# ========================================================

# App Environment (local, test, staging, production)
APP_ENV=local

# Core Django Secrets
DJANGO_SECRET=django-insecure-default-change-me-in-production-environments

# FastAPI Secrets
FASTAPI_SECRET=fastapi-default-change-me-in-production-environments

# Database Configurations
DATABASE_URL=postgres://postgres:postgrespassword@db:5432/whatsapp_agent

# Third-party Integrations
OPENAI_KEY=your-openai-service-api-key
META_TOKEN=your-meta-whatsapp-cloud-api-token
EMAIL_KEY=your-email-provider-transmissions-key
